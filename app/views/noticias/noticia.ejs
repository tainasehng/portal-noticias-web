<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width-device-width,initial-scale-1">
	<title>Notícia</title>
</head>
<body>
<h1>Notícia</h1>
	<% if (noticia.length > 0) { %>
	  <table>
	    <tr>
	      <td>ID</td>
	      <td>Título</td>
	      <td>Notícia</td>
	    </tr>
	    <tr>
	      <td><%= noticia[0].id_noticia %></td>
	      <td><%= noticia[0].titulo %></td>
	      <td><%= noticia[0].noticia %></td>
	    </tr>
	  </table>
	<% } else { %>
	  <p>Notícia não encontrada.</p>
	<% } %>

</body>
</html>
